# Copy this file to .env and fill in real values. Never commit .env.

# SQLite database file location (used by Prisma)
DATABASE_URL="file:./dev.db"

# Google Gemini API key — get a free one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Model to use for chat replies
GEMINI_MODEL=gemini-2.5-flash

# Port the backend HTTP server listens on
PORT=4000

# Comma-separated list of origins allowed to call this API (CORS)
CORS_ORIGIN=http://localhost:5173
